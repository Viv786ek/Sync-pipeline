# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# On Render: use the Internal Database URL from your Render PostgreSQL instance
DATABASE_URL=postgresql://user:password@localhost:5432/sync_pipeline

# ─── HubSpot CRM ──────────────────────────────────────────────────────────────
# Create a free HubSpot developer account at https://developers.hubspot.com
# Then: Settings → Integrations → Private Apps → Create private app
# Required scopes: crm.objects.contacts.read, crm.objects.deals.read
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Test key from: https://dashboard.stripe.com/test/apikeys
# Use sk_test_... for test mode; sk_live_... for production
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Calendar OAuth2 ────────────────────────────────────────────────────
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the Google Calendar API
# 3. Create OAuth 2.0 credentials (Web application type)
# 4. Add your server's /api/auth/google/callback as an authorised redirect URI
# 5. Hit GET /api/auth/google/init → open the URL → approve → copy refresh_token
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://your-app.onrender.com/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_ID=primary

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
